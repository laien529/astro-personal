---
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import SeoHead from '@/components/layout/SeoHead.astro';
import { siteConfig } from '@/data/site';
import { getStyleClass, getStyleName, getThemeCss } from '@/utils/theme';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  navItems?: {
    label: string;
    labelEn?: string;
    href: string;
  }[];
  language?: string;
  showLanguageToggle?: boolean;
  showHeaderContacts?: boolean;
  hideFooterContacts?: boolean;
  bodyStyle?: string;
  brandName?: string;
  brandIcon?: string;
  brandHref?: string;
  faviconHref?: string;
}

const {
  title,
  description,
  navItems,
  language = siteConfig.language,
  showLanguageToggle = false,
  showHeaderContacts = false,
  hideFooterContacts = false,
  bodyStyle,
  brandName = siteConfig.name,
  brandIcon,
  brandHref = '/',
  faviconHref
} = Astro.props;
const themeCss = getThemeCss();
const styleClass = getStyleClass();
const styleName = getStyleName();
---

<!doctype html>
<html lang={language}>
  <head>
    <SeoHead title={title} description={description} faviconHref={faviconHref} />
    <style is:inline set:html={themeCss}></style>
  </head>
  <body class={styleClass} data-style={styleName} style={bodyStyle}>
    <Navbar
      navItems={navItems}
      showLanguageToggle={showLanguageToggle}
      showHeaderContacts={showHeaderContacts}
      brandName={brandName}
      brandIcon={brandIcon}
      brandHref={brandHref}
    />
    <main>
      <slot />
    </main>
    <Footer hideContactLinks={hideFooterContacts} />
  </body>
</html>

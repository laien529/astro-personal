---
import Tag from '@/components/ui/Tag.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  tech: string[];
  cover?: string;
  coverAlt?: string;
}

const { href, title, summary, tech, cover, coverAlt } = Astro.props;
---

<a class="card project-card" href={href}>
  {cover && <img class="project-card-cover" src={cover} alt={coverAlt ?? ''} loading="lazy" />}
  <div>
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
  <div class="tag-list">
    {tech.map((item) => <Tag text={item} />)}
  </div>
</a>

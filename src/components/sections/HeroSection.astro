---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import ContentMedia from '@/components/media/ContentMedia.astro';
import type { HeroSectionConfig } from '@/data/pageContent';

interface Props {
  config: HeroSectionConfig;
}

const { config } = Astro.props;
const sectionClass = ['section', 'hero-section', config.spacing === 'tight' && 'section-tight']
  .filter(Boolean)
  .join(' ');
---

<section class={sectionClass}>
  <Container>
    <div class="hero-grid">
      <div>
        {config.eyebrow && <p class="section-eyebrow">{config.eyebrow}</p>}
        <h1>{config.title}</h1>
        {config.lead && <p class="lead">{config.lead}</p>}
        {config.body && <p class="hero-copy">{config.body}</p>}
        {config.actions && (
          <div class="button-row">
            {config.actions.map((action) => (
              <Button href={action.href} variant={action.variant} external={action.external}>{action.label}</Button>
            ))}
          </div>
        )}
      </div>
      {(config.panel || config.media) && (
        <div class="panel hero-panel">
          {config.panel && (
            <>
              {config.panel.label && <p class="hero-panel-label">{config.panel.label}</p>}
              <ul class="hero-list">
                {config.panel.items.map((item) => <li>{item}</li>)}
              </ul>
            </>
          )}
          {config.media && <ContentMedia media={config.media} className="hero-media" />}
        </div>
      )}
    </div>
  </Container>
</section>

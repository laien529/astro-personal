---
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import SocialLink from '@/components/ui/SocialLink.astro';
import type { ContactSectionConfig } from '@/data/pageContent';

interface Props {
  config: ContactSectionConfig;
}

const { config } = Astro.props;
const sectionClass = ['section', config.spacing === 'tight' && 'section-tight'].filter(Boolean).join(' ');
---

<section class={sectionClass}>
  <Container>
    <SectionHeader
      eyebrow={config.header.eyebrow}
      title={config.header.title}
      description={config.header.description}
      align={config.header.align}
    />
    <div class="contact-grid">
      {config.cards.map((card) => (
        <div class="panel">
          <h3>{card.title}</h3>
          {card.link && <p><a href={card.link.href}>{card.link.label}</a></p>}
          {card.body && <p class="muted">{card.body}</p>}
          {card.links && (
            <div class="social-list vertical">
              {card.links.map((item) => <SocialLink label={item.label} href={item.href} external={item.external} />)}
            </div>
          )}
        </div>
      ))}
    </div>
  </Container>
</section>

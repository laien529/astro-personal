---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import type { CtaSectionConfig } from '@/data/pageContent';

interface Props {
  config: CtaSectionConfig;
}

const { config } = Astro.props;
const sectionClass = ['section', config.spacing === 'tight' && 'section-tight'].filter(Boolean).join(' ');
---

<section class={sectionClass}>
  <Container>
    <div class="cta-box panel">
      {config.eyebrow && <p class="section-eyebrow">{config.eyebrow}</p>}
      <h2>{config.title}</h2>
      {config.body && <p>{config.body}</p>}
      {config.actions && (
        <div class="button-row">
          {config.actions.map((action) => (
            <Button href={action.href} variant={action.variant} external={action.external}>{action.label}</Button>
          ))}
        </div>
      )}
    </div>
  </Container>
</section>

---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { siteConfig } from '@/data/site';
---

<section class="section">
  <Container>
    <div class="cta-box panel">
      <p class="section-eyebrow">Contact</p>
      <h2>Need a landing page, portfolio, or product showcase?</h2>
      <p>Use this project as a clean base, then swap in your own brand, content, and deployment settings.</p>
      <div class="button-row">
        <Button href={`mailto:${siteConfig.email}`}>Email Me</Button>
        <Button href="/contact" variant="secondary">Contact Page</Button>
      </div>
    </div>
  </Container>
</section>

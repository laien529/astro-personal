---
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import ContentMedia from '@/components/media/ContentMedia.astro';
import type { SplitTextSectionConfig } from '@/data/pageContent';

interface Props {
  config: SplitTextSectionConfig;
}

const { config } = Astro.props;
const sectionClass = ['section', config.spacing === 'tight' && 'section-tight'].filter(Boolean).join(' ');
---

<section class={sectionClass}>
  <Container>
    <SectionHeader
      eyebrow={config.header.eyebrow}
      title={config.header.title}
      description={config.header.description}
      align={config.header.align}
    />
    <div class="two-column panel">
      <div>
        {config.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        {config.meta && <p class="muted">{config.meta}</p>}
      </div>
      {config.media && <ContentMedia media={config.media} className="section-media" />}
    </div>
  </Container>
</section>

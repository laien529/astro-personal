---
import Container from '@/components/ui/Container.astro';
import type { ResolvedOperatingContent } from '@/utils/operatingContent';

interface Props {
  content: ResolvedOperatingContent;
}

const { content } = Astro.props;
const projectStyle = content.backgroundColor ? `--ops-project-bg: ${content.backgroundColor};` : undefined;
---

<div class="ops-project" style={projectStyle}>
  <section class="section ops-title-section" aria-labelledby="ops-project-title">
    <Container>
      <div class="ops-title-shell">
        {content.subtitle && (
          <p class="ops-title-subtitle">
            {content.subtitleEn ? <span data-zh={content.subtitle} data-en={content.subtitleEn}>{content.subtitle}</span> : content.subtitle}
          </p>
        )}
        <h1 id="ops-project-title">
          {content.mainTitleEn ? <span data-zh={content.mainTitle} data-en={content.mainTitleEn}>{content.mainTitle}</span> : content.mainTitle}
        </h1>
        {content.intro && (
          <p class="ops-title-intro">
            {content.introEn ? <span data-zh={content.intro} data-en={content.introEn}>{content.intro}</span> : content.intro}
          </p>
        )}
      </div>
    </Container>
  </section>
  {content.modules.map((module, moduleIndex) => {
    const reversed = moduleIndex % 2 === 1;
    const hasMedia = Boolean(module.backgroundImage);
    const hasItems = module.items.length > 0;

    return (
      <section class="section ops-module" id={`module-${moduleIndex + 1}`}>
        <Container>
          <div class:list={['ops-module-shell', reversed && 'ops-module-shell-reversed', !hasMedia && 'ops-module-shell-no-media']}>
            {hasMedia && (
              <figure class="ops-module-media">
                <img src={module.backgroundImage} alt={module.title} loading={moduleIndex === 0 ? 'eager' : 'lazy'} />
              </figure>
            )}
            <div class="ops-module-content">
              <div class="section-header ops-module-header">
                <h2>
                  {module.titleEn ? <span data-zh={module.title} data-en={module.titleEn}>{module.title}</span> : module.title}
                </h2>
                <p class="section-description">
                  {module.introEn ? <span data-zh={module.intro} data-en={module.introEn}>{module.intro}</span> : module.intro}
                </p>
              </div>
            </div>
            {hasItems && (
              <div class="ops-scroll-region" data-ops-carousel>
                <div class="ops-item-list" data-ops-track>
                  {module.items.map((item) => (
                    <article class:list={['ops-item-card', item.images.length === 0 && 'ops-item-card-text-only']}>
                      <div class="ops-item-copy">
                        <h3>
                          {item.titleEn ? <span data-zh={item.title} data-en={item.titleEn}>{item.title}</span> : item.title}
                        </h3>
                        <p>
                          {item.introEn ? <span data-zh={item.intro} data-en={item.introEn}>{item.intro}</span> : item.intro}
                        </p>
                      </div>
                      {item.images.length > 0 && (
                        <div class="ops-image-list" aria-label={`${item.title} images`}>
                          {item.images.map((image, index) => (
                            <img src={image} alt={`${item.title} ${index + 1}`} loading="lazy" />
                          ))}
                        </div>
                      )}
                    </article>
                  ))}
                </div>
                {module.items.length > 1 && (
                  <div class="ops-scroll-controls is-visible" aria-label="滚动控制" data-ops-controls>
                    <div class="ops-scroll-dots">
                      {module.items.map((_, index) => (
                        <button class:list={['ops-scroll-dot', index === 0 && 'active']} type="button" aria-label={`查看第 ${index + 1} 项`} data-ops-dot={index}></button>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        </Container>
      </section>
    );
  })}
</div>

<script is:inline>
  (() => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animationDuration = 560;
    const easeInOut = (progress) =>
      progress < 0.5
        ? 4 * progress * progress * progress
        : 1 - Math.pow(-2 * progress + 2, 3) / 2;

    document.querySelectorAll('[data-ops-carousel]').forEach((carousel) => {
      const track = carousel.querySelector('[data-ops-track]');
      const dots = Array.from(carousel.querySelectorAll('.ops-scroll-dot'));
      if (!track) return;

      let scrollAnimation = 0;
      let scrollFrame = 0;
      let isAnimating = false;
      let activeIndex = -1;
      let cardTargets = [];

      const getCards = () => Array.from(track.querySelectorAll('.ops-item-card'));
      const refreshTargets = () => {
        const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);
        cardTargets = getCards().map((card) => {
          const centeredLeft = card.offsetLeft - (track.clientWidth - card.offsetWidth) / 2;
          return Math.max(0, Math.min(maxScroll, centeredLeft));
        });
      };
      const nearestIndex = () => {
        if (cardTargets.length === 0) refreshTargets();
        const left = track.scrollLeft;
        let index = 0;
        let distance = Number.POSITIVE_INFINITY;
        cardTargets.forEach((targetLeft, currentIndex) => {
          const nextDistance = Math.abs(targetLeft - left);
          if (nextDistance < distance) {
            distance = nextDistance;
            index = currentIndex;
          }
        });
        return index;
      };
      const setActiveIndex = (index) => {
        if (index === activeIndex) return;
        activeIndex = index;
        dots.forEach((dot, currentIndex) => {
          dot.classList.toggle('active', currentIndex === index);
          dot.setAttribute('aria-current', currentIndex === index ? 'true' : 'false');
        });
      };
      const cancelScrollAnimation = () => {
        cancelAnimationFrame(scrollAnimation);
        isAnimating = false;
        track.classList.remove('is-programmatic-scroll');
      };
      const scrollToIndex = (index) => {
        refreshTargets();
        const targetLeft = cardTargets[index];
        if (typeof targetLeft !== 'number') return;

        setActiveIndex(index);
        if (prefersReducedMotion) {
          track.scrollLeft = targetLeft;
          return;
        }

        cancelScrollAnimation();
        isAnimating = true;
        track.classList.add('is-programmatic-scroll');
        const startLeft = track.scrollLeft;
        const distance = targetLeft - startLeft;
        const startTime = performance.now();

        const step = (time) => {
          const progress = Math.min(1, (time - startTime) / animationDuration);
          const eased = easeInOut(progress);
          track.scrollLeft = startLeft + distance * eased;
          if (progress < 1) {
            scrollAnimation = requestAnimationFrame(step);
          } else {
            isAnimating = false;
            track.classList.remove('is-programmatic-scroll');
            setActiveIndex(nearestIndex());
          }
        };

        scrollAnimation = requestAnimationFrame(step);
      };
      const updateDots = () => {
        if (isAnimating) return;
        setActiveIndex(nearestIndex());
      };

      carousel.style.setProperty('--ops-scroll-duration', `${animationDuration}ms`);
      refreshTargets();
      track.addEventListener('scroll', () => {
        if (scrollFrame) return;
        scrollFrame = requestAnimationFrame(() => {
          scrollFrame = 0;
          updateDots();
        });
      }, { passive: true });
      track.addEventListener('pointerdown', cancelScrollAnimation, { passive: true });
      track.addEventListener('touchstart', cancelScrollAnimation, { passive: true });
      track.addEventListener('wheel', cancelScrollAnimation, { passive: true });
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          if (!dot.classList.contains('active')) {
            scrollToIndex(index);
          }
        });
      });
      window.addEventListener('resize', () => {
        refreshTargets();
        const index = nearestIndex();
        if (dots[index]) {
          scrollToIndex(index);
        }
      });
      updateDots();
    });
  })();
</script>

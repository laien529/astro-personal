---
import Container from '@/components/ui/Container.astro';
import SocialLink from '@/components/ui/SocialLink.astro';
import { siteConfig } from '@/data/site';
import { getOperatingContactLinks } from '@/utils/operatingContent';

interface Props {
  hideContactLinks?: boolean;
}

const { hideContactLinks = false } = Astro.props;
const contactLinks = getOperatingContactLinks(siteConfig.footer.contactLinks);
---

<footer class="site-footer">
  <Container>
    <div class="site-footer-inner">
      <p>{siteConfig.footer.text}</p>
      {!hideContactLinks && (
        <div class="social-list">
          {contactLinks.map((item) => (
            <SocialLink label={item.label} labelEn={item.labelEn} href={item.href} />
          ))}
        </div>
      )}
    </div>
  </Container>
</footer>

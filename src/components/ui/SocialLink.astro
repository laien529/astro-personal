};
---

<a class="social-link" href={normalizedHref} target={external ? '_blank' : undefined} rel={external ? 'noreferrer' : undefined} data-social-type={socialType}>
  <span class="social-icon" set:html={icons[socialType] ?? icons.link}></span>
  {labelEn ? <span data-zh={label} data-en={labelEn}>{label}</span> : label}
</a>

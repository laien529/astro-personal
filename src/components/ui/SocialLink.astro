    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.5 6.75A2.75 2.75 0 0 1 6.25 4h11.5a2.75 2.75 0 0 1 2.75 2.75v10.5A2.75 2.75 0 0 1 17.75 20H6.25a2.75 2.75 0 0 1-2.75-2.75V6.75Zm2.15-.55 6.35 5.3 6.35-5.3a1.2 1.2 0 0 0-.6-.15H6.25c-.22 0-.42.05-.6.15Zm13.1 2.05-5.82 4.86a1.45 1.45 0 0 1-1.86 0L5.25 8.25v9c0 .55.45 1 1 1h11.5c.55 0 1-.45 1-1v-9Z"/></svg>',

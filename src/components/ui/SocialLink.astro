  linkedin:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.2 8.8h3.15v10.1H6.2V8.8Zm1.58-5a1.82 1.82 0 1 1 0 3.64 1.82 1.82 0 0 1 0-3.64Zm3.55 5h3.02v1.38h.04c.42-.8 1.45-1.64 2.99-1.64 3.2 0 3.79 2.1 3.79 4.84v5.52h-3.15v-4.9c0-1.17-.02-2.67-1.63-2.67-1.63 0-1.88 1.27-1.88 2.58v4.99h-3.18V8.8Z"/></svg>',

---
interface Props {
  label: string;
  labelEn?: string;
  href: string;
  external?: boolean;
}

const { label, labelEn, href } = Astro.props;

function resolveSocialType(label: string, href: string) {
  const value = `${label} ${href}`.toLowerCase();

  if (value.includes('mailto:') || value.includes('email') || value.includes('邮箱') || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(href)) {
    return 'email';
  }
  if (value.includes('github.com') || value.includes('github')) return 'github';
  if (value.includes('linkedin.com') || value.includes('linkedin') || value.includes('领英')) return 'linkedin';
  if (value.includes('instagram.com') || value.includes('instagram') || /\bins\b/.test(value)) return 'instagram';
  if (value.includes('twitter.com') || value.includes('x.com') || value === 'x') return 'x';
  if (value.includes('douyin.com') || value.includes('tiktok.com') || value.includes('抖音')) return 'douyin';
  if (value.includes('xiaohongshu.com') || value.includes('xhs') || value.includes('小红书')) return 'xiaohongshu';
  if (value.includes('dianping.com') || value.includes('大众点评')) return 'dianping';
  return 'link';
}

const socialType = resolveSocialType(label, href);
const normalizedHref = socialType === 'email' && !href.startsWith('mailto:') ? `mailto:${href}` : href;
const external = normalizedHref.startsWith('http');
const icons: Record<string, string> = {

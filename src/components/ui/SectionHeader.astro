---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={["section-header", align === 'center' && 'section-header-center']}>
  {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p class="section-description">{description}</p>}
</div>

---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  external?: boolean;
}

const { href, variant = 'primary', external = false } = Astro.props;
const opensNewTab = external || href.startsWith('http');
const classes = variant === 'primary' ? 'btn btn-primary' : 'btn btn-secondary';
---

<a class={classes} href={href} target={opensNewTab ? '_blank' : undefined} rel={opensNewTab ? 'noreferrer' : undefined}>
  <slot />
</a>

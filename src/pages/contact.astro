---
import MainLayout from '@/layouts/MainLayout.astro';
import ContactFormSection from '@/components/sections/ContactFormSection.astro';
import { pageContent } from '@/data/pageContent';

const page = pageContent.contact;
---

<MainLayout title={page.meta.title} description={page.meta.description}>
  {page.sections.map((section) => (
    section.enabled === false ? null :
    section.type === 'contact' ? <ContactFormSection config={section} /> :
    null
  ))}
</MainLayout>

import ContactCtaSection from '@/components/sections/ContactCtaSection.astro';
import { siteConfig } from '@/data/site';
---

<MainLayout title={siteConfig.title} description={siteConfig.description}>
  <HeroSection />
  <AboutPreviewSection />
  <FeaturedProjectsSection />
  <SkillsSection />
  <ContactCtaSection />
</MainLayout>
